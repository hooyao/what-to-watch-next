{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key-here"
      }
    },
    "example-http-search": {
      "type": "http",
      "url": "https://your-search-endpoint.example/mcp",
      "headers": {
        "x-api-key": "your-api-key-here"
      }
    }
  }
}
